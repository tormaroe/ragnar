#!/usr/bin/env bash

# Exit on error
set -e

# Path to csproj relative to git root
CSPROJ="src/Ragnar.csproj"

# Ensure we are running inside the git repository and CSPROJ exists
if [ ! -f "$CSPROJ" ]; then
    exit 0
fi

# Check if there are any staged changes (excluding csproj changes)
# This prevents prompting if we are just amending or doing git commit without staging files
STAGED_FILES=$(git diff --cached --name-only | grep -v "src/Ragnar.csproj" || true)
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Check if stdout is a TTY and we can redirect stdin to /dev/tty
if [ -t 1 ] && [ -c /dev/tty ] && exec < /dev/tty 2>/dev/null; then
    # We successfully redirected stdin from the controlling terminal
    :
else
    echo "Non-interactive environment detected. Skipping version prompt."
    exit 0
fi

# Read current Version from csproj
VERSION_LINE=$(grep -oE '<Version>[0-9]+\.[0-9]+\.[0-9]+</Version>' "$CSPROJ" || true)
if [ -z "$VERSION_LINE" ]; then
    VERSION_LINE=$(grep '<Version>' "$CSPROJ" || true)
fi

if [[ "$VERSION_LINE" =~ \<Version\>([0-9]+)\.([0-9]+)\.([0-9]+)\<\/Version\> ]]; then
    MAJOR="${BASH_REMATCH[1]}"
    MINOR="${BASH_REMATCH[2]}"
    PATCH="${BASH_REMATCH[3]}"
else
    echo "Warning: Could not parse <Version> from $CSPROJ. Current version not found."
    exit 0
fi

CURRENT_VERSION="$MAJOR.$MINOR.$PATCH"

echo ""
echo "=============================================="
echo " Ragnar Version Bump"
echo " Current version: $CURRENT_VERSION"
echo "=============================================="
echo "Select version bump:"
echo "  1) Major    -> $((MAJOR + 1)).0.0"
echo "  2) Minor    -> $MAJOR.$((MINOR + 1)).0"
echo "  3) Revision -> $MAJOR.$MINOR.$((PATCH + 1))"
echo "  4) None     -> Keep $CURRENT_VERSION"
echo "=============================================="
read -p "Choose option [1-4]: " Choice

case "$Choice" in
    1)
        NEW_VERSION="$((MAJOR + 1)).0.0"
        ;;
    2)
        NEW_VERSION="$MAJOR.$((MINOR + 1)).0"
        ;;
    3)
        NEW_VERSION="$MAJOR.$MINOR.$((PATCH + 1))"
        ;;
    *)
        echo "No version bump requested."
        exit 0
        ;;
esac

echo "Bumping version from $CURRENT_VERSION to $NEW_VERSION..."

# Use Perl for cross-platform replacement
perl -pi -e "s|<Version>$CURRENT_VERSION</Version>|<Version>$NEW_VERSION</Version>|g" "$CSPROJ"

# Stage the updated project file
git add "$CSPROJ"
echo "Successfully updated version to $NEW_VERSION and staged $CSPROJ."
